{
  "title": "LLM Inference Platform",
  "uid": "llm-platform",
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "llm-model replicas (KEDA scale-out)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "min": 0,
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas{deployment=\"llm-model\"}",
          "legendFormat": "desired replicas",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"llm-model\"}",
          "legendFormat": "ready replicas",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "In-flight requests (KEDA trigger signal, threshold 2)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal"
            }
          },
          "min": 0,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(llamacpp:requests_processing)",
          "legendFormat": "processing",
          "refId": "A"
        },
        {
          "expr": "sum(llamacpp:requests_deferred)",
          "legendFormat": "deferred (queued)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Gateway latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "min": 0,
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket{path=\"/v1/chat/completions\"}[2m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket{path=\"/v1/chat/completions\"}[2m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Token throughput (generated tokens/sec, all replicas)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "min": 0,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llamacpp:tokens_predicted_total[2m]))",
          "legendFormat": "tokens/sec",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
